# ─── Telegram (Required) ──────────────────────────────────────────────────────
TELEGRAM_API_ID=your_api_id_from_my_telegram_org
TELEGRAM_API_HASH=your_api_hash_from_my_telegram_org

# ─── Supabase (Required) ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Gemini AI (Required for Phase 4 categorization) ─────────────────────────
GEMINI_API_KEY=your_gemini_api_key_from_aistudio.google.com

# ─── Google Drive (Optional — export works without these) ─────────────────────
# Create a service account in Google Cloud Console, share your target Drive
# folder with the service account email, then set the paths/IDs below.
GOOGLE_DRIVE_CREDENTIALS_JSON=/abs/path/to/service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id

# ─── Local directories (Optional — defaults shown) ────────────────────────────
EXPORT_DIR=exports
DOWNLOAD_DIR=downloads

# ─── CORS (Optional) ──────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the Next.js frontend
CORS_ORIGINS=["http://localhost:3000"]

# ─── Features (Optional) ──────────────────────────────────────────────────────
ENABLE_WHISPER=false
